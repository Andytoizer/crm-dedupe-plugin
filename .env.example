# ============================================================
# Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# HubSpot private app token.
# Scopes needed: crm.objects.contacts.read/write, crm.objects.companies.read/write
HUBSPOT_ACCESS_TOKEN=

# Anthropic API key used by review/ai_review.py.
ANTHROPIC_API_KEY=

# Optional Slack digest settings.
SLACK_BOT_TOKEN=
SLACK_REVIEW_CHANNEL=#hubspot-dedup-review

# SQLite database path.
DB_PATH=./dedup.db

# Scheduled/live mode flag. Keep false for safe default behavior.
DEDUP_LIVE=false
