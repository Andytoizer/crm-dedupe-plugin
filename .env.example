# Path to a local checkout of https://github.com/Andytoizer/crm-dedupe-agent
CRM_DEDUPE_AGENT_REPO=/path/to/crm-dedupe-agent

# The CRM Dedupe Agent repo reads these when running live workflows.
# Keep real values in that repo's local .env, not in this plugin repo.
HUBSPOT_ACCESS_TOKEN=
ANTHROPIC_API_KEY=
SLACK_REVIEW_CHANNEL=#hubspot-dedup-review
